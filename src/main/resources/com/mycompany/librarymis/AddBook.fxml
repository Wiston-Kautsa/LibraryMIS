<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="414.0" prefWidth="436.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.librarymis.AddBookController">

    <stylesheets>
        <URL value="@addbook.css" />
    </stylesheets>

    <children>
        <VBox alignment="TOP_CENTER" prefHeight="414.0" prefWidth="436.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <children>

                <Label alignment="CENTER" prefHeight="27.0" prefWidth="225.0" text="BOOK INFORMATION" wrapText="true">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" left="50.0" right="50.0" top="10.0" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="bookTitle" promptText="Book Title">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                    </VBox.margin>
                </TextField>

                <TextField fx:id="bookID" promptText="Book ID">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                    </VBox.margin>
                </TextField>

                <TextField fx:id="bookAuthor" promptText="Book Author">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                    </VBox.margin>
                </TextField>

                <TextField fx:id="publisher" promptText="Publisher">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                    </VBox.margin>
                </TextField>

                <HBox>
                    <VBox.margin>
                        <Insets bottom="10.0" left="5.0" right="5.0" top="5.0" />
                    </VBox.margin>

                    <children>

                        <Button fx:id="save" mnemonicParsing="false" onAction="#saveButton" prefWidth="300.0" text="Save">
                            <HBox.margin>
                                <Insets bottom="2.0" left="10.0" right="10.0" top="2.0" />
                            </HBox.margin>
                        </Button>

                        <Button fx:id="cancel" mnemonicParsing="false" onAction="#cancelButton" prefWidth="300.0" text="Cancel">
                            <HBox.margin>
                                <Insets bottom="2.0" left="10.0" right="10.0" top="2.0" />
                            </HBox.margin>
                        </Button>

                    </children>
                </HBox>

            </children>

            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

        </VBox>
    </children>

</AnchorPane>
