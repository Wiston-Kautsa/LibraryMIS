<AnchorPane id="AnchorPane" prefHeight="332.0" prefWidth="482.0" styleClass="mainFxmlClass" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.mycompany.librarymis.AddMemberController">
