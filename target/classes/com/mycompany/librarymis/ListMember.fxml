<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="301.0" prefWidth="445.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.librarymis.ListMemberController">

    <stylesheets>
        <URL value="@listmember.css" />
    </stylesheets>

    <children>

        <TableView fx:id="tableView"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.topAnchor="0.0">

            <columns>

                <TableColumn fx:id="nameCol" text="Name" prefWidth="100"/>

                <TableColumn fx:id="idCol" text="Member ID" prefWidth="100"/>

                <TableColumn fx:id="mobileCol" text="Mobile" prefWidth="120"/>

                <TableColumn fx:id="emailCol" text="Email" prefWidth="150"/>

                <TableColumn fx:id="borrowedCol" text="Borrowed Book" prefWidth="120"/>

            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

        </TableView>

    </children>

</AnchorPane>