<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="221.0" prefWidth="254.0" styleClass="mainFxmlClass" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.mycompany.librarymis.SettingsController">
    <stylesheets>
        <URL value="@settings.css" />
    </stylesheets>
   <children>
      <VBox prefHeight="241.0" prefWidth="254.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="258.0" text="SETTINGS">
               <VBox.margin>
                  <Insets bottom="5.0" left="20.0" right="20.0" />
               </VBox.margin>
            </Button>
            <TextField fx:id="nDaysWithoutFine" promptText="Number of days member can keep book without fine">
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="finePerDay" layoutX="10.0" layoutY="40.0" promptText="Fine per day">
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="username" layoutX="10.0" layoutY="65.0" promptText="Username">
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </TextField>
            <PasswordField fx:id="password" promptText="Password">
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </PasswordField>
         </children>
      </VBox>
      <HBox alignment="CENTER" layoutX="9.0" layoutY="177.0" prefHeight="50.0" prefWidth="255.0">
         <children>
            <Button fx:id="save" mnemonicParsing="false" onAction="#saveButtonAction" prefHeight="25.0" prefWidth="99.0" text="Save">
               <HBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="cancel" layoutX="84.0" layoutY="10.0" mnemonicParsing="false" onAction="#cancelButtonAction" prefHeight="25.0" prefWidth="99.0" text="Cancel">
               <HBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </children>
</AnchorPane>
